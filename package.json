{
  "name": "zevkershman-web",
  "version": "1.0.0",
  "description": "Personal website for Zev Kershman",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "serve": "npx serve . -p 3000",
    "start": "npx serve . -p 3000",
    "validate:html": "html-validate index.html 404.html",
    "validate:css": "stylelint 'css/**/*.css'",
    "test:unit": "node --test tests/unit/",
    "test:integration": "npx playwright test tests/integration/",
    "test:a11y": "npx playwright test tests/accessibility/",
    "test:visual": "npx playwright test tests/visual/",
    "test:visual:update": "npx playwright test tests/visual/ --update-snapshots",
    "lighthouse": "npx @lhci/cli autorun"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.48.0",
    "html-validate": "^8.24.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
